# EditorConfig for QBasic Nexus
# Ensures consistent coding style across editors

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{json,yml,yaml}]
indent_size = 2

[*.js]
indent_size = 2
max_line_length = 100

[*.bas]
indent_size = 4
