{
    "name": "qbasic-nexus",
    "displayName": "QBasic Nexus",
    "description": "The Most Advanced, Lightning-Fast QBasic & QB64 Development Environment Ever Built for VS Code 🚀.",
    "version": "1.5.9",
    "publisher": "Thirawat27",
    "author": "Thirawat27",
    "license": "MIT",
    "icon": "assets/QBasicNexus.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/thirawat27/QBasic-Nexus"
    },
    "bugs": {
        "url": "https://github.com/thirawat27/QBasic-Nexus/issues"
    },
    "homepage": "https://github.com/thirawat27/QBasic-Nexus#readme",
    "engines": {
        "vscode": "^1.107.0"
    },
    "main": "./extension.js",
    "scripts": {
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "pretest": "npm run lint",
        "test": "npm run test:compiler && npm run test:run && npm run test:variables && npm run test:features && npm run test:integration && npm run test:autodetect && npm run test:workspace && npm run test:webview && npm run test:tutorial && npm run test:todo && npm run test:optimizations && npm run test:executables && npm run test:buildsettings && npm run test:systemsettings",
        "benchmark": "npm run benchmark:compiler && npm run benchmark:editor",
        "benchmark:compiler": "node test/benchmark-compiler.js",
        "benchmark:editor": "node test/benchmark-editor.js",
        "test:compiler": "node test/test-transpiler.js",
        "test:run": "node test/test-compile-and-run.js",
        "test:variables": "node test/test-variable-declaration.js",
        "test:features": "node test/test-editor-features.js",
        "test:integration": "node test/test-integration.js",
        "test:autodetect": "node test/test-qb64-autodetect.js",
        "test:workspace": "node test/test-workspace-multi.js",
        "test:webview": "node test/test-webview-manager.js",
        "test:todo": "node test/test-todo-provider.js",
        "test:tutorial": "node test/test-tutorial-manager.js",
        "test:optimizations": "node test/test-optimization-managers.js",
        "test:executables": "node test/test-executable-utils.js",
        "test:buildsettings": "node test/test-internal-build-settings.js",
        "test:systemsettings": "node test/test-system-settings.js",
        "test:all": "npm run test:compiler && npm run test:run && npm run test:variables && npm run test:features && npm run test:integration && npm run test:autodetect && npm run test:workspace && npm run test:webview && npm run test:tutorial && npm run test:todo && npm run test:optimizations && npm run test:executables && npm run test:buildsettings && npm run test:systemsettings && npm run benchmark",
        "generate:snippets": "node scripts/generate-snippets.js",
        "package": "vsce package",
        "publish": "vsce publish"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "25.x",
        "@types/vscode": "^1.107.0",
        "eslint": "^10.2.1",
        "globals": "^17.5.0",
        "tinybench": "6.0.0"
    },
    "dependencies": {
        "@yao-pkg/pkg": "6.17.0",
        "defu": "^6.1.7",
        "flru": "^1.0.2",
        "magic-string": "^0.30.21",
        "mitt": "^3.0.1",
        "moo": "^0.5.3"
    },
    "categories": [
        "Programming Languages",
        "Snippets",
        "Formatters",
        "Linters"
    ],
    "keywords": [
        "qbasic",
        "quickbasic",
        "qb64",
        "basic",
        "retro",
        "compiler",
        "programming",
        "ide"
    ],
    "contributes": {
        "languages": [
            {
                "id": "qbasic",
                "aliases": [
                    "QBasic",
                    "QuickBASIC",
                    "QB64"
                ],
                "extensions": [
                    ".bas",
                    ".bi",
                    ".bm",
                    ".inc"
                ],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./assets/qb64.svg",
                    "dark": "./assets/qb64.svg"
                }
            }
        ],
        "commands": [
            {
                "command": "qbasic-nexus.configureSystem",
                "title": "QBasic Configure System ⚙️",
                "icon": "$(settings-gear)"
            },
            {
                "command": "qbasic-nexus.selectCompilerMode",
                "title": "QBasic Select Compiler Mode 🧭",
                "icon": "$(compass)"
            },
            {
                "command": "qbasic-nexus.selectCompilerPath",
                "title": "QBasic Configure QB64 Path 🛤️",
                "icon": "$(tools)"
            },
            {
                "command": "qbasic-nexus.selectCompilerArgs",
                "title": "QBasic Configure QB64 Args 🧪",
                "icon": "$(symbol-parameter)"
            },
            {
                "command": "qbasic-nexus.compile",
                "title": "QBasic Compile 🔨",
                "icon": "$(tools)"
            },
            {
                "command": "qbasic-nexus.compileAndRun",
                "title": "QBasic Compile & Run 🌀",
                "icon": "$(play)"
            },
            {
                "command": "qbasic-nexus.runInCrt",
                "title": "QBasic Run in Retro CRT 📺",
                "icon": "$(device-desktop)"
            },
            {
                "command": "qbasic-nexus.startTutorial",
                "title": "QBasic Start Interactive Tutorial 🎮",
                "icon": "$(mortar-board)"
            },
            {
                "command": "qbasic-nexus.showCodeStats",
                "title": "QBasic Show Code Statistics 📊",
                "icon": "$(graph)"
            },
            {
                "command": "qbasic-nexus.removeLineNumbers",
                "title": "QBasic Remove Line Numbers 🔢",
                "icon": "$(list-ordered)"
            },
            {
                "command": "qbasic-nexus.renumberLines",
                "title": "QBasic Renumber Lines 🔄",
                "icon": "$(symbol-number)"
            },
            {
                "command": "qbasic-nexus.showAsciiChart",
                "title": "QBasic Show ASCII Chart 📋",
                "icon": "$(symbol-string)"
            },
            {
                "command": "qbasic-nexus.insertChrFromAsciiChart",
                "title": "QBasic Insert CHR$() at Cursor ✍️",
                "icon": "$(insert)"
            },
            {
                "command": "qbasic-nexus.refreshTodo",
                "title": "Refresh TODOs 🔄",
                "icon": "$(refresh)"
            },
            {
                "command": "qbasic-nexus.showInternalBuildQuickActions",
                "title": "QBasic Internal Build Quick Actions ⚙️",
                "icon": "$(settings-gear)"
            },
            {
                "command": "qbasic-nexus.selectInternalTargets",
                "title": "QBasic Select Internal Build Targets 🎯",
                "icon": "$(package)"
            },
            {
                "command": "qbasic-nexus.selectInternalOutputDir",
                "title": "QBasic Select Internal Output Folder 📂",
                "icon": "$(folder-opened)"
            },
            {
                "command": "qbasic-nexus.selectCompileWorkerResilience",
                "title": "QBasic Tune Compile Worker Resilience 🛡️",
                "icon": "$(pulse)"
            },
            {
                "command": "qbasic-nexus.selectLintWorkerResilience",
                "title": "QBasic Tune Lint Worker Resilience 🛡️",
                "icon": "$(pulse)"
            },
            {
                "command": "qbasic-nexus.selectEnableLinting",
                "title": "QBasic Configure Linting 🩺",
                "icon": "$(check)"
            },
            {
                "command": "qbasic-nexus.selectLintDelay",
                "title": "QBasic Set Lint Delay ⏱️",
                "icon": "$(history)"
            },
            {
                "command": "qbasic-nexus.selectAutoFormat",
                "title": "QBasic Configure Auto Format 💾",
                "icon": "$(paintcan)"
            },
            {
                "command": "qbasic-nexus.selectLineNumberSettings",
                "title": "QBasic Set Line Number Defaults 🔢",
                "icon": "$(symbol-number)"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "command": "qbasic-nexus.compile",
                    "when": "resourceLangId == qbasic",
                    "group": "1_qbasic@1"
                },
                {
                    "command": "qbasic-nexus.compileAndRun",
                    "when": "resourceLangId == qbasic",
                    "group": "1_qbasic@2"
                },
                {
                    "command": "qbasic-nexus.runInCrt",
                    "when": "resourceLangId == qbasic",
                    "group": "1_qbasic@3"
                },
                {
                    "command": "qbasic-nexus.startTutorial",
                    "when": "resourceLangId == qbasic",
                    "group": "1_qbasic@4"
                },
                {
                    "command": "qbasic-nexus.removeLineNumbers",
                    "when": "resourceLangId == qbasic",
                    "group": "2_qbasicTools@1"
                },
                {
                    "command": "qbasic-nexus.renumberLines",
                    "when": "resourceLangId == qbasic",
                    "group": "2_qbasicTools@2"
                },
                {
                    "command": "qbasic-nexus.showAsciiChart",
                    "when": "resourceLangId == qbasic",
                    "group": "2_qbasicTools@3"
                },
                {
                    "command": "qbasic-nexus.insertChrFromAsciiChart",
                    "when": "resourceLangId == qbasic",
                    "group": "2_qbasicTools@4"
                }
            ],
            "editor/title": [
                {
                    "command": "qbasic-nexus.compileAndRun",
                    "when": "resourceLangId == qbasic",
                    "group": "navigation"
                },
                {
                    "command": "qbasic-nexus.configureSystem",
                    "when": "resourceLangId == qbasic",
                    "group": "navigation@1"
                },
                {
                    "command": "qbasic-nexus.runInCrt",
                    "when": "resourceLangId == qbasic",
                    "group": "navigation@2"
                }
            ],
            "view/title": [
                {
                    "command": "qbasic-nexus.refreshTodo",
                    "when": "view == qbasic-todo",
                    "group": "navigation"
                }
            ]
        },
        "keybindings": [
            {
                "command": "qbasic-nexus.compileAndRun",
                "key": "f5",
                "when": "resourceLangId == qbasic"
            },
            {
                "command": "qbasic-nexus.compile",
                "key": "ctrl+shift+b",
                "when": "resourceLangId == qbasic"
            },
            {
                "command": "qbasic-nexus.showCodeStats",
                "key": "ctrl+shift+i",
                "when": "resourceLangId == qbasic"
            },
            {
                "command": "qbasic-nexus.removeLineNumbers",
                "key": "ctrl+alt+r",
                "when": "editorTextFocus && resourceLangId == qbasic"
            },
            {
                "command": "qbasic-nexus.renumberLines",
                "key": "ctrl+alt+n",
                "when": "editorTextFocus && resourceLangId == qbasic"
            },
            {
                "command": "qbasic-nexus.showAsciiChart",
                "key": "ctrl+alt+a",
                "when": "resourceLangId == qbasic"
            }
        ],
        "grammars": [
            {
                "language": "qbasic",
                "scopeName": "source.qbasic",
                "path": "./syntaxes/qbasic.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "qbasic",
                "path": "./snippets/qbasic.json"
            }
        ],
        "configuration": {
            "title": "QBasic Nexus",
            "properties": {
                "qbasic-nexus.compilerPath": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "default": null,
                    "markdownDescription": "Full path to your **QB64** executable.\n\n**Examples:**\n- Windows: `C:\\QB64\\qb64.exe`\n- macOS: `/Applications/QB64/qb64`\n- Linux: `~/qb64/qb64`\n\nLeave empty for auto-detection.",
                    "scope": "machine"
                },
                "qbasic-nexus.compilerMode": {
                    "type": "string",
                    "enum": [
                        "QB64 (Recommended)",
                        "Qbasic Nexus"
                    ],
                    "enumDescriptions": [
                        "Compile with QB64 for native executable (best performance)",
                        "Transpile QBasic to JavaScript via the internal engine, then package one or more standalone executables using @yao-pkg/pkg"
                    ],
                    "default": "QB64 (Recommended)",
                    "markdownDescription": "Select the compilation mode.",
                    "scope": "resource"
                },
                "qbasic-nexus.compilerArgs": {
                    "type": "string",
                    "default": "",
                    "markdownDescription": "Additional arguments for the QB64 compiler.\n\n**Examples:** `-w` (warnings), `-g` (debug)",
                    "scope": "resource"
                },
                "qbasic-nexus.internalTargets": {
                    "type": "string",
                    "default": "host",
                    "markdownDescription": "Packager target(s) for **Qbasic Nexus** internal builds.\n\nUse `host` for the current machine, or a comma-separated list such as `win-x64`, `linux-x64`, `macos-arm64`, or `host,linux-x64`.\n\nCommon aliases like `windows-x64`, `darwin-arm64`, `osx-arm64`, `amd64`, `aarch64`, and `current` are normalized automatically.\n\nWhen multiple targets are specified, outputs are written into the configured internal output folder and **Compile & Run** skips auto-run unless you switch back to a single host target.",
                    "scope": "resource"
                },
                "qbasic-nexus.internalOutputDir": {
                    "type": "string",
                    "default": "",
                    "markdownDescription": "Output directory for **Qbasic Nexus** internal builds.\n\nLeave empty to write beside the source file. Relative paths resolve from the workspace folder when available; absolute paths and `~/...` home-relative paths are also supported.\n\nSingle-target builds write the executable into this folder. Multi-target builds write all generated binaries there.",
                    "scope": "resource"
                },
                "qbasic-nexus.compileWorkerMaxQueueSize": {
                    "type": "number",
                    "default": 64,
                    "minimum": 1,
                    "markdownDescription": "Maximum compile requests allowed in the shared worker queue before backpressure starts.\n\nWhen this limit is reached, new compile requests are resolved through the safe fallback path instead of growing memory usage.",
                    "scope": "resource"
                },
                "qbasic-nexus.compileWorkerRequestTimeoutMs": {
                    "type": "number",
                    "default": 30000,
                    "minimum": 0,
                    "markdownDescription": "Timeout in milliseconds for an in-flight compile worker request.\n\nSet to `0` to disable timeouts. When a request times out, the worker is recycled and the request falls back to the in-process compiler.",
                    "scope": "resource"
                },
                "qbasic-nexus.lintWorkerMaxQueueSize": {
                    "type": "number",
                    "default": 96,
                    "minimum": 1,
                    "markdownDescription": "Maximum lint requests allowed in the shared worker queue before backpressure starts.\n\nWhen this limit is reached, new lint requests are resolved through the safe fallback linter to keep the editor responsive.",
                    "scope": "resource"
                },
                "qbasic-nexus.lintWorkerRequestTimeoutMs": {
                    "type": "number",
                    "default": 15000,
                    "minimum": 0,
                    "markdownDescription": "Timeout in milliseconds for an in-flight lint worker request.\n\nSet to `0` to disable timeouts. When a request times out, the worker is recycled and diagnostics are computed via the fallback path.",
                    "scope": "resource"
                },
                "qbasic-nexus.enableLinting": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "Enable real-time syntax checking and error highlighting.",
                    "scope": "resource"
                },
                "qbasic-nexus.lintDelay": {
                    "type": "number",
                    "default": 500,
                    "minimum": 100,
                    "maximum": 3000,
                    "markdownDescription": "Delay in milliseconds before linting after typing stops. Lower values = faster feedback but more CPU usage.",
                    "scope": "resource"
                },
                "qbasic-nexus.autoFormatOnSave": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "Automatically format the document and auto-capitalize keywords when saving (mimicking classic QBasic IDE).",
                    "scope": "resource"
                },
                "qbasic-nexus.lineNumberStart": {
                    "type": "number",
                    "default": 1,
                    "minimum": 1,
                    "markdownDescription": "Starting line number used by **QBasic: Renumber Lines**.",
                    "scope": "resource"
                },
                "qbasic-nexus.lineNumberStep": {
                    "type": "number",
                    "default": 1,
                    "minimum": 1,
                    "markdownDescription": "Increment used by **QBasic: Renumber Lines**.",
                    "scope": "resource"
                }
            }
        },
        "views": {
            "explorer": [
                {
                    "id": "qbasic-todo",
                    "name": "QBasic TODOs",
                    "icon": "assets/QBasicNexus.png"
                }
            ]
        }
    }
}
